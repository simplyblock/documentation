Options +FollowSymlinks
RewriteEngine On

# Keep only /latest indexable. Numbered version dirs (25.x, 26.x, ...) and the
# /dev development build are crawlable but noindex; they canonicalize to /latest.
# Do NOT also Disallow these in robots.txt, or Google can't crawl to see noindex.
<IfModule mod_headers.c>
  SetEnvIf Request_URI "^/[0-9]"    NOINDEX
  SetEnvIf Request_URI "^/dev(/|$)" NOINDEX
  Header set X-Robots-Tag "noindex" env=NOINDEX
</IfModule>

# Old documentation redirects
RewriteRule ^deployment/deployment /latest/deployments/ [L,R=301]
RewriteRule ^deployment/requirements /latest/deployments/deployment-preparation/ [L,R=301]
RewriteRule ^usage/linux /latest/deployments/install-simplyblock/ [L,R=301]
RewriteRule ^operation/maintenance /latest/maintenance-operations/ [L,R=301]
RewriteRule ^known_issues /latest/important-notes/known-issues/ [L,R=301]
RewriteRule ^cli_reference /latest/reference/cli/ [L,R=301]
RewriteRule ^api_reference /latest/reference/api-sdk/ [L,R=301]
RewriteRule ^operation/monitoring /latest/maintenance-operations/monitoring/ [L,R=301]
RewriteRule ^important_concepts /latest/architecture/concepts/ [L,R=301]
RewriteRule ^usage/storagepools_volumes /latest/usage/baremetal/ [L,R=301]
RewriteRule ^latest/deployments/deployment-planning/recommendations /latest/deployments/deployment-preparation/ [L,R=301]
RewriteRule ^latest/deployments/baremetal/install-simplyblock-csi /latest/deployments/kubernetes/install-csi/ [L,R=301]
RewriteRule ^latest/deployments/kubernetes/install-simplyblock/hyper-converged /latest/deployments/kubernetes/k8s-hyperconverged/ [L,R=301]
RewriteRule ^latest/deployments/aws-ec2 /latest/deployments/install-simplyblock/ [L,R=301]
RewriteRule ^latest/deployments/deployment-planning/network-considerations /latest/deployments/deployment-preparation/system-requirements/#network-requirements [L,R=301]
RewriteRule ^latest/deployments/kubernetes/data-migration /latest/deployments/data-migration/ [L,R=301]
RewriteRule ^latest/deployments/kubernetes/install-simplyblock /latest/deployments/install-simplyblock/ [L,R=301]
RewriteRule ^latest/deployments/deployment-planning/node-sizing /latest/deployments/deployment-preparation/node-sizing/ [L,R=301]
RewriteRule ^latest/deployments/deployment-planning/erasure-coding-scheme /latest/deployments/deployment-preparation/erasure-coding-scheme/ [L,R=301]

# New internal redirects
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
Header always set Cache-Control "no-cache, no-store, must-revalidate"
Header always set Pragma "no-cache"
Header always set Expires 0
RewriteCond %{REQUEST_URI} !^/latest/
RewriteRule (.+) /latest/$1 [L,R=301]
RewriteCond %{REQUEST_URI} !^/latest/
RewriteRule ^$ /latest/ [L,R=301]
